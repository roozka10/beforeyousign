# Required Environment Variables for beforeyousign

# OpenRouter API Key (free tier available)
# Get from: https://openrouter.ai
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase Configuration
# Get from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Hardcoded in code (no need to add to env):
# - VITE_OPENROUTER_MODEL = google/gemma-2-27b-it:free
# - VITE_USER_LOCATION = United States

# --- Monetization (optional — add after affiliate approvals) ---
# Sovrn Commerce: auto-converts partner links → https://www.sovrn.com/publishers/commerce/
# VITE_SOVRN_PUBLISHER_KEY=your_sovrn_publisher_key

# Amazon Associates store ID → https://affiliate-program.amazon.com/
# VITE_AMAZON_ASSOCIATE_TAG=beforeyousign-20

# Paste full tracking URLs from CJ / ShareASale / Impact after approval:
# VITE_AFFILIATE_LEGALZOOM_URL=https://...
# VITE_AFFILIATE_ROCKETLAWYER_URL=https://...
# VITE_AFFILIATE_DOCUSIGN_URL=https://...
# VITE_AFFILIATE_PRIVACY_URL=https://...
# VITE_AFFILIATE_AMAZON_BOOK_URL=https://...
